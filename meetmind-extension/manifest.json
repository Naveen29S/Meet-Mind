{
  "manifest_version": 3,
  "name": "MeetMind Web Recorder",
  "version": "1.0",
  "description": "Capture audio from any web meeting directly into MeetMind.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
